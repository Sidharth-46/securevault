# ── Required ─────────────────────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
RESET_WEB_URL=https://securevaultsid.vercel.app
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_service_account.json

# ── Recommended (change in production) ───────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Optional (defaults shown) ───────────────────────────────────────────────
# JWT_EXPIRY_HOURS=24
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_FROM=            (defaults to EMAIL_USER if empty)
